//  ADMIN — Derived from User (Inheritance Relationship 6)
// ══════════════════════════════════════════════════════════════════════════════
class Admin : public User {
private:
    string adminLevel;   // "SuperAdmin" / "Moderator"
    int    casesHandled;
    bool   canBanUsers;
    string department;
    string adminCode;    // internal secret code

public:
    // Default constructor
    Admin() : User(), adminLevel("Moderator"), casesHandled(0),
              canBanUsers(false), department("General"), adminCode("0000") {}

    // Parameterized constructor — level and department known at creation
    Admin(const string& id, const string& name, const string& email,
          const string& phone, const string& pass,
          const string& level, const string& dept, const string& code)
        : User(id, name, email, phone, pass),
          adminLevel(level), casesHandled(0),
          canBanUsers(level == "SuperAdmin"),
          department(dept), adminCode(code) {}

    string getRole() const override { return "Admin"; }

    // Getters
    string getAdminLevel()   const { return adminLevel; }
    int    getCasesHandled() const { return casesHandled; }
    string getDepartment()   const { return department; }

    void handleCase() { casesHandled++; }

    void banUser(User& u) {
        if (canBanUsers) {
            u.deactivate();
            cout << "[ADMIN] " << name << " banned: " << u.getName() << "\n";
            handleCase();
        } else {
            cout << "[DENIED] Insufficient admin level.\n";
        }
    }

    void unbanUser(User& u) {
        if (canBanUsers) {
            u.activate();
            cout << "[ADMIN] " << name << " unbanned: " << u.getName() << "\n";
        }
    }

    void promoteToVerified(Seller& s) {
        s.verify();
        cout << "[ADMIN] Seller " << s.getName() << " is now verified.\n";
        handleCase();
    }

    void displayDetails() const override {
        User::displayDetails();
        cout << "  Level: " << adminLevel
             << " | Dept: " << department
             << " | Cases: " << casesHandled
             << " | CanBan: " << (canBanUsers ? "Yes" : "No") << "\n";
    }

    // Friend function declaration
    // Justification: internal system needs to validate admin code
    // without exposing it publicly
    friend bool validateAdminCode(const Admin& a, const string& code);
};

// Friend Function 3: Validate admin secret code
bool validateAdminCode(const Admin& a, const string& code) {
    return a.adminCode == code;
}


class Listing : public IDisplayable, public IApprovable, public ISearchable {
private:
    string   listingID;
    double   askingPrice;
    string   description;
    bool     approved;
    string   rejectionReason;
    string   sellerID;      

    Vehicle* vehicle;       
    Location location;      

    
    static int totalListings;

   
    static const double PLATFORM_FEE;

public:
    // Default constructor
    Listing() : listingID("L000"), askingPrice(0), description(""),
                approved(false), rejectionReason(""), sellerID(""),
                vehicle(nullptr), location() {
        totalListings++;
    }

    // Parameterized constructor
    Listing(const string& id, double price, const string& desc,
            const string& sellerID, Vehicle* v, const Location& loc)
        : listingID(id), askingPrice(price), description(desc),
          approved(false), rejectionReason(""), sellerID(sellerID),
          vehicle(v), location(loc) {
        totalListings++;
    }

    // Copy constructor 
    Listing(const Listing& l)
        : listingID(l.listingID + "_copy"), askingPrice(l.askingPrice),
          description(l.description), approved(false),
          rejectionReason(""), sellerID(l.sellerID),
          vehicle(nullptr), location(l.location) {
        if (l.vehicle) {
            if (l.vehicle->getType() == "Car")
                vehicle = new Car(*dynamic_cast<Car*>(l.vehicle));
            else if (l.vehicle->getType() == "Bike")
                vehicle = new Bike(*dynamic_cast<Bike*>(l.vehicle));
            else if (l.vehicle->getType() == "Truck")
                vehicle = new Truck(*dynamic_cast<Truck*>(l.vehicle));
        }
        totalListings++;
    }

    ~Listing() {
        delete vehicle; 
    }

    
    void approve() override {
        approved = true;
        rejectionReason = "";
        cout << "[APPROVED] Listing " << listingID << "\n";
    }

    void reject(const char* reason) override {
        approved = false;
        rejectionReason = reason;
        cout << "[REJECTED] Listing " << listingID << ": " << reason << "\n";
    }

    bool isApproved() const override { return approved; }

    // Getters
    string   getListingID()   const { return listingID; }
    double   getAskingPrice() const { return askingPrice; }
    string   getDescription() const { return description; }
    string   getSellerID()    const { return sellerID; }
    Vehicle* getVehicle()     const { return vehicle; }
    Location getLocation()    const { return location; }

    // Setters
    void setAskingPrice(double p)         { askingPrice = p; }
    void setDescription(const string& d)  { description = d; }
    void setLocation(const Location& loc) { location = loc; }

    static int    getTotalListings() { return totalListings; }
    static double getPlatformFee()   { return PLATFORM_FEE; }

    // ISearchable — delegates to embedded vehicle
    bool matchesFilter(const string& key, const string& value) const override {
        if (key == "city") return location.getCity() == value;
        if (key == "price") {
            try { return askingPrice <= stod(value); }
            catch (...) { return false; }
        }
        if (vehicle) return vehicle->matchesFilter(key, value);
        return false;
    }

    void displayDetails() const override {
        cout << "\n========================================\n";
        cout << "Listing ID : " << listingID << "\n";
        cout << "Price      : Rs " << askingPrice << "\n";
        cout << "Status     : " << (approved ? "APPROVED" : "PENDING/REJECTED") << "\n";
        cout << "Location   : "; location.displayDetails(); cout << "\n";
        cout << "Seller ID  : " << sellerID << "\n";
        cout << "Description: " << description << "\n";
        if (vehicle) vehicle->displayDetails();
        cout << "Platform Fee: Rs " << PLATFORM_FEE << "\n";
        cout << "========================================\n";
    }

    // Operator overloading
    bool operator<(const Listing& other) const { return askingPrice < other.askingPrice; }
    bool operator==(const Listing& other) const { return listingID == other.listingID; }

    // Operator +:
    Listing operator+(const string& extraDesc) const {
        Listing copy(*this);
        copy.description += " | " + extraDesc;
        return copy;
    }
};

