//  BUYER — Derived from User (Inheritance Relationship 4)
// ══════════════════════════════════════════════════════════════════════════════
class Buyer : public User {
private:
    string preferredBrand;
    double maxBudget;
    string preferredCity;
    bool   wantsFinancing;

    // Array of objects: saved favourite listing IDs
    static const int MAX_FAVS = 20;
    string favourites[MAX_FAVS];
    int    favCount;

public:
    // Default constructor — buyer signs up without specifying preferences yet
    Buyer() : User(), preferredBrand("Any"), maxBudget(0),
              preferredCity("Any"), wantsFinancing(false), favCount(0) {}

    // Parameterized constructor — budget and city known at registration
    Buyer(const string& id, const string& name, const string& email,
          const string& phone, const string& pass,
          double budget, const string& city)
        : User(id, name, email, phone, pass),
          preferredBrand("Any"), maxBudget(budget),
          preferredCity(city), wantsFinancing(false), favCount(0) {}

    // Copy constructor — used when cloning a buyer profile
    Buyer(const Buyer& b)
        : User(b), preferredBrand(b.preferredBrand), maxBudget(b.maxBudget),
          preferredCity(b.preferredCity), wantsFinancing(b.wantsFinancing),
          favCount(b.favCount) {
        for (int i = 0; i < favCount; i++) favourites[i] = b.favourites[i];
    }

    string getRole() const override { return "Buyer"; }

    // Getters
    double getMaxBudget()     const { return maxBudget; }
    string getPreferredCity() const { return preferredCity; }
    int    getFavCount()      const { return favCount; }

    // Setters
    void setMaxBudget(double b)             { maxBudget = b; }
    void setPreferredBrand(const string& b) { preferredBrand = b; }
    void setWantsFinancing(bool w)          { wantsFinancing = w; }

    void saveFavourite(const string& listingID) {
        for (int i = 0; i < favCount; i++)
            if (favourites[i] == listingID) {
                cout << "[INFO] Already in favourites.\n"; return;
            }
        if (favCount < MAX_FAVS) {
            favourites[favCount++] = listingID;
            cout << "[OK] Listing " << listingID << " saved to favourites.\n";
        }
    }

    void removeFavourite(const string& listingID) {
        for (int i = 0; i < favCount; i++) {
            if (favourites[i] == listingID) {
                for (int j = i; j < favCount - 1; j++)
                    favourites[j] = favourites[j + 1];
                favCount--;
                cout << "[OK] Removed from favourites.\n";
                return;
            }
        }
        cout << "[ERR] Not found in favourites.\n";
    }

    void viewFavourites() const {
        cout << "=== Favourites for " << name << " ===\n";
        for (int i = 0; i < favCount; i++)
            cout << "  " << (i + 1) << ". " << favourites[i] << "\n";
    }

    void displayDetails() const override {
        User::displayDetails();
        cout << "  Budget: Rs " << maxBudget
             << " | City: " << preferredCity
             << " | Favs: " << favCount << "\n";
    }

    // Friend function declaration
    // Justification: canAfford() needs read access to private maxBudget
    // without exposing a setter — friend keeps it controlled and read-only
    friend bool canAfford(const Buyer& buyer, double price);
};

// Friend Function 1: Checks if buyer's budget covers the asking price
bool canAfford(const Buyer& buyer, double price) {
    return buyer.maxBudget >= price;
}


