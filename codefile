#include <iostream>
#include <string>
using namespace std;

// Abstract Class 1: Forces every entity to implement displayDetails()
class IDisplayable {
public:
    virtual void displayDetails() const = 0;
    virtual ~IDisplayable() {}
};

// Abstract Class 2: Any searchable entity must implement matchesFilter()
class ISearchable {
public:
    virtual bool matchesFilter(const string& key, const string& value) const = 0;
    virtual ~ISearchable() {}
};

// Abstract Class 3: Admin-manageable entities must implement approve/reject
class IApprovable {
public:
    virtual void approve() = 0;
    virtual void reject(const char* reason) = 0;
    virtual bool isApproved() const = 0;
    virtual ~IApprovable() {}
};

// Abstract Class 4: Any entity that can send/receive messages
class IMessagable {
public:
    virtual void sendMessage(const string& to, const string& msg) = 0;
    virtual void readMessages() const = 0;
    virtual ~IMessagable() {}
};



class Location : public IDisplayable {
private:
    string city;
    string province;
    string country;
    double latitude;
    double longitude;

public:
    // Default constructor
    Location() : city("Unknown"), province("Unknown"), country("Pakistan"),
                 latitude(0.0), longitude(0.0) {}

    // Parameterized constructor 
    Location(const string& city, const string& province,
             const string& country = "Pakistan",
             double lat = 0.0, double lon = 0.0)
        : city(city), province(province), country(country),
          latitude(lat), longitude(lon) {}

    // Copy constructor 
    Location(const Location& other)
        : city(other.city), province(other.province), country(other.country),
          latitude(other.latitude), longitude(other.longitude) {}

    // Getters
    string getCity()      const { return city; }
    string getProvince()  const { return province; }
    string getCountry()   const { return country; }
    double getLatitude()  const { return latitude; }
    double getLongitude() const { return longitude; }

    // Setters
    void setCity(const string& c)     { city = c; }
    void setProvince(const string& p) { province = p; }

    // Member functions
    void displayDetails() const override {
        cout << city << ", " << province << ", " << country;
    }

    string toString() const {
        return city + ", " + province + ", " + country;
    }

    bool isSameCity(const Location& other) const {
        return city == other.city;
    }

    void updateCoordinates(double lat, double lon) {
        latitude = lat;
        longitude = lon;
    }

    // Operator overloading: == compares city + province
    bool operator==(const Location& other) const {
        return city == other.city && province == other.province;
    }
};


class Message : public IDisplayable {
private:
    string senderID;
    string receiverID;
    string content;
    string timestamp;
    bool   isRead;

public:
    // Default constructor 
    Message() : senderID(""), receiverID(""), content(""),
                timestamp(""), isRead(false) {}

    // Parameterized constructor 
    Message(const string& from, const string& to,
            const string& text, const string& time)
        : senderID(from), receiverID(to), content(text),
          timestamp(time), isRead(false) {}

    // Copy constructor 
    Message(const Message& m)
        : senderID(m.senderID), receiverID(m.receiverID),
          content(m.content), timestamp(m.timestamp), isRead(m.isRead) {}

    // Getters
    string getSenderID()   const { return senderID; }
    string getReceiverID() const { return receiverID; }
    string getContent()    const { return content; }
    string getTimestamp()  const { return timestamp; }
    bool   getIsRead()     const { return isRead; }

    // Setters
    void markRead() { isRead = true; }

    void displayDetails() const override {
        cout << "[" << timestamp << "] From: " << senderID
             << " -> To: " << receiverID
             << " | " << (isRead ? "READ" : "UNREAD") << "\n"
             << "  \"" << content << "\"\n";
    }

    bool operator==(const Message& other) const {
        return senderID == other.senderID &&
               receiverID == other.receiverID &&
               timestamp == other.timestamp;
    }
};

//  VEHICLE — Abstract Base Class

class Vehicle : public IDisplayable, public ISearchable {
protected:
    string brand;
    string model;
    int    year;
    double mileage;
    string fuelType;
    string color;

    static int totalVehicles;

public:
    // Default constructor
    Vehicle() : brand("Unknown"), model("Unknown"), year(2020),
                mileage(0), fuelType("Petrol"), color("White") {
        totalVehicles++;
    }

    // Parameterized constructor 
    Vehicle(const string& brand, const string& model, int year,
            double mileage, const string& fuelType, const string& color)
        : brand(brand), model(model), year(year),
          mileage(mileage), fuelType(fuelType), color(color) {
        totalVehicles++;
    }

    // Copy constructor 
    Vehicle(const Vehicle& v)
        : brand(v.brand), model(v.model), year(v.year),
          mileage(v.mileage), fuelType(v.fuelType), color(v.color) {
        totalVehicles++;
    }

    virtual ~Vehicle() {}

    // Pure virtual 
    virtual string getType() const = 0;
    virtual void displayDetails() const override = 0;

    // Getters
    string getBrand()    const { return brand; }
    string getModel()    const { return model; }
    int    getYear()     const { return year; }
    double getMileage()  const { return mileage; }
    string getFuelType() const { return fuelType; }
    string getColor()    const { return color; }

    // Setters
    void setBrand(const string& b)    { brand = b; }
    void setModel(const string& m)    { model = m; }
    void setYear(int y)               { year = y; }
    void setMileage(double m)         { mileage = m; }
    void setFuelType(const string& f) { fuelType = f; }
    void setColor(const string& c)    { color = c; }

    // Static member function 
    static int getTotalVehicles() { return totalVehicles; }

    // ISearchable 
    bool matchesFilter(const string& key, const string& value) const override {
        if (key == "brand") return brand == value;
        if (key == "model") return model == value;
        if (key == "fuel")  return fuelType == value;
        if (key == "color") return color == value;
        if (key == "year")  return to_string(year) == value;
        return false;
    }

    // Operator overloading
    bool operator>(const Vehicle& other) const { return year > other.year; }
    bool operator==(const Vehicle& other) const {
        return brand == other.brand && model == other.model && year == other.year;
    }
};

int Vehicle::totalVehicles = 0;


//  CAR — Derived from Vehicle (Inheritance Relationship 1)

class Car : public Vehicle {
private:
    int    numDoors;
    string transmission;   
    string bodyType;     
    double engineCC;
    bool   isAC;

public:
    // Default constructor 
    Car() : Vehicle(), numDoors(4), transmission("Manual"),
            bodyType("Sedan"), engineCC(1300), isAC(true) {}

    // Parameterized constructor 
    Car(const string& brand, const string& model, int year,
        double mileage, const string& fuel, const string& color,
        int doors, const string& trans, const string& body,
        double cc, bool ac)
        : Vehicle(brand, model, year, mileage, fuel, color),
          numDoors(doors), transmission(trans),
          bodyType(body), engineCC(cc), isAC(ac) {}

    // Copy constructor — used during deep copy in Listing copy constructor
    Car(const Car& c)
        : Vehicle(c), numDoors(c.numDoors), transmission(c.transmission),
          bodyType(c.bodyType), engineCC(c.engineCC), isAC(c.isAC) {}

    string getType() const override { return "Car"; }

    // Overrides Vehicle::displayDetails() — polymorphism
    void displayDetails() const override {
        cout << "[CAR] " << year << " " << brand << " " << model
             << " | " << bodyType << " | " << transmission
             << " | " << engineCC << "cc | Doors: " << numDoors
             << " | AC: " << (isAC ? "Yes" : "No")
             << " | Fuel: " << fuelType
             << " | Mileage: " << mileage << " km"
             << " | Color: " << color << "\n";
    }

    // Getters
    int    getNumDoors()     const { return numDoors; }
    string getTransmission() const { return transmission; }
    string getBodyType()     const { return bodyType; }
    double getEngineCC()     const { return engineCC; }
    bool   getIsAC()         const { return isAC; }

    // Setters
    void setTransmission(const string& t) { transmission = t; }
    void setBodyType(const string& b)     { bodyType = b; }
    void setEngineCC(double cc)           { engineCC = cc; }

    double estimateAnnualTax() const {
        if (engineCC <= 1000) return 10000;
        if (engineCC <= 1300) return 15000;
        if (engineCC <= 1600) return 25000;
        return 50000;
    }

    bool matchesFilter(const string& key, const string& value) const override {
        if (key == "body")         return bodyType == value;
        if (key == "transmission") return transmission == value;
        return Vehicle::matchesFilter(key, value);
    }
};


