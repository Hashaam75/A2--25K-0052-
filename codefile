class Review : public IDisplayable {
private:
    string reviewID;
    string buyerID;
    string sellerID;
    int    rating;          
    string comment;
    string datePosted;
    bool   isVerifiedPurchase;

public:
    // Default constructor 
    Review() : reviewID("R000"), buyerID(""), sellerID(""),
               rating(0), comment(""), datePosted(""), isVerifiedPurchase(false) {}

    // Parameterized constructor
    Review(const string& id, const string& buyer, const string& seller,
           int rating, const string& comment, const string& date, bool verified)
        : reviewID(id), buyerID(buyer), sellerID(seller),
          rating(rating), comment(comment), datePosted(date),
          isVerifiedPurchase(verified) {}

    // Copy constructor
    Review(const Review& r)
        : reviewID(r.reviewID), buyerID(r.buyerID), sellerID(r.sellerID),
          rating(r.rating), comment(r.comment), datePosted(r.datePosted),
          isVerifiedPurchase(r.isVerifiedPurchase) {}

    // Getters
    string getReviewID() const { return reviewID; }
    string getBuyerID()  const { return buyerID; }
    string getSellerID() const { return sellerID; }
    int    getRating()   const { return rating; }
    string getComment()  const { return comment; }

    // Setters
    void setComment(const string& c) { if (!c.empty()) comment = c; }

    bool isPositive() const { return rating >= 4; }
    bool isNegative() const { return rating <= 2; }

    string getRatingStars() const {
        string stars = "";
        for (int i = 0; i < rating; i++) stars += "*";
        return stars;
    }

    void displayDetails() const override {
        cout << "[Review " << reviewID << "] "
             << getRatingStars() << " (" << rating << "/5)\n"
             << "  Buyer: " << buyerID << " -> Seller: " << sellerID << "\n"
             << "  \"" << comment << "\"\n"
             << "  Date: " << datePosted
             << " | Verified: " << (isVerifiedPurchase ? "Yes" : "No") << "\n";
    }

    // Operator overloading
    bool operator>(const Review& other) const  { return rating > other.rating; }
    bool operator==(const Review& other) const { return reviewID == other.reviewID; }
};


//  MARKETPLACE — Central Registry
//  COMPOSITION:  owns all Listing objects (deletes them in destructor)
//  AGGREGATION:  holds User* pointers (users exist independently, not deleted here)
class Marketplace {
private:
    string platformName;
    string version;
    string baseURL;

    static const int MAX_LISTINGS = 100;
    static const int MAX_USERS    = 200;
    static const int MAX_REVIEWS  = 300;

    Listing* listings[MAX_LISTINGS]; 
    int      listingCount;

    User*    users[MAX_USERS];      
    int      userCount;

    Review   reviews[MAX_REVIEWS];   
    int      reviewCount;

    
    static int totalSearches;

public:
    // Default constructor
    Marketplace()
        : platformName("PakWheels Clone"), version("1.0"), baseURL("www.pakwheels.pk"),
          listingCount(0), userCount(0), reviewCount(0) {
        for (int i = 0; i < MAX_LISTINGS; i++) listings[i] = nullptr;
        for (int i = 0; i < MAX_USERS; i++)    users[i]    = nullptr;
    }

    // Parameterized constructor
    Marketplace(const string& name, const string& ver, const string& url)
        : platformName(name), version(ver), baseURL(url),
          listingCount(0), userCount(0), reviewCount(0) {
        for (int i = 0; i < MAX_LISTINGS; i++) listings[i] = nullptr;
        for (int i = 0; i < MAX_USERS; i++)    users[i]    = nullptr;
    }

    ~Marketplace() {
        for (int i = 0; i < listingCount; i++) delete listings[i]; // COMPOSITION

    }

    // ── User Management 
    void registerUser(User* u) {
        if (userCount < MAX_USERS) {
            users[userCount++] = u;
            cout << "[OK] Registered: " << u->getName() << " (" << u->getRole() << ")\n";
        }
    }

    User* findUser(const string& id) const {
        for (int i = 0; i < userCount; i++)
            if (users[i]->getUserID() == id) return users[i];
        return nullptr;
    }

    // ── Listing Management 
    bool addListing(Listing* l) {
        if (listingCount >= MAX_LISTINGS) {
            cout << "[ERR] Marketplace full.\n"; return false;
        }
        listings[listingCount++] = l;
        User* u = findUser(l->getSellerID());
        if (u && u->getRole() == "Seller")
            dynamic_cast<Seller*>(u)->incrementListings();
        cout << "[OK] Listing " << l->getListingID() << " added (pending approval).\n";
        return true;
    }

    bool deleteListing(const string& id, const string& requesterID) {
        for (int i = 0; i < listingCount; i++) {
            if (listings[i]->getListingID() == id) {
                User* u = findUser(requesterID);
                if (!u) { cout << "[ERR] Unknown requester.\n"; return false; }
                bool isSeller = (listings[i]->getSellerID() == requesterID);
                bool isAdmin  = (u->getRole() == "Admin");
                if (!isSeller && !isAdmin) {
                    cout << "[DENIED] Not authorized.\n"; return false;
                }
                User* seller = findUser(listings[i]->getSellerID());
                if (seller && seller->getRole() == "Seller")
                    dynamic_cast<Seller*>(seller)->decrementListings();
                delete listings[i];
                for (int j = i; j < listingCount - 1; j++)
                    listings[j] = listings[j + 1];
                listings[--listingCount] = nullptr;
                cout << "[OK] Listing " << id << " deleted.\n";
                return true;
            }
        }
        cout << "[ERR] Listing not found.\n";
        return false;
    }

    bool updateListingPrice(const string& id, double newPrice, const string& sellerID) {
        for (int i = 0; i < listingCount; i++) {
            if (listings[i]->getListingID() == id &&
                listings[i]->getSellerID() == sellerID) {
                listings[i]->setAskingPrice(newPrice);
                cout << "[OK] Price updated to Rs " << newPrice << "\n";
                return true;
            }
        }
        cout << "[ERR] Not found or unauthorized.\n";
        return false;
    }

    // ── Admin Approval 
    void approveListing(const string& id, Admin& admin) {
        for (int i = 0; i < listingCount; i++) {
            if (listings[i]->getListingID() == id) {
                listings[i]->approve();
                admin.handleCase();
                return;
            }
        }
        cout << "[ERR] Listing not found.\n";
    }

    void rejectListing(const string& id, const char* reason, Admin& admin) {
        for (int i = 0; i < listingCount; i++) {
            if (listings[i]->getListingID() == id) {
                listings[i]->reject(reason);
                admin.handleCase();
                return;
            }
        }
        cout << "[ERR] Listing not found.\n";
    }

    // ── Search & Filter 
    // Polymorphism: matchesFilter() calls the correct Vehicle subclass override
    void searchListings(const string& key, const string& value) const {
        totalSearches++;
        cout << "\n=== Search: " << key << " = " << value << " ===\n";
        int found = 0;
        for (int i = 0; i < listingCount; i++) {
            if (listings[i]->isApproved() && listings[i]->matchesFilter(key, value)) {
                listings[i]->displayDetails();
                found++;
            }
        }
        if (found == 0) cout << "No results found.\n";
        else cout << found << " result(s) found.\n";
    }

    void filterByMaxPrice(double maxPrice) const {
        totalSearches++;
        cout << "\n=== Filter: Price <= Rs " << maxPrice << " ===\n";
        for (int i = 0; i < listingCount; i++)
            if (listings[i]->isApproved() && listings[i]->getAskingPrice() <= maxPrice)
                listings[i]->displayDetails();
    }

    void filterByYearRange(int minYear, int maxYear) const {
        totalSearches++;
        cout << "\n=== Filter: Year " << minYear << " - " << maxYear << " ===\n";
        for (int i = 0; i < listingCount; i++) {
            if (!listings[i]->isApproved()) continue;
            Vehicle* v = listings[i]->getVehicle();
            if (v && v->getYear() >= minYear && v->getYear() <= maxYear)
                listings[i]->displayDetails();
        }
    }

    // ── Messaging 
    void sendMessage(const string& fromID, const string& toID,
                     const string& content, const string& timestamp) {
        User* sender   = findUser(fromID);
        User* receiver = findUser(toID);
        if (!sender || !receiver) { cout << "[ERR] User not found.\n"; return; }
        Message m(fromID, toID, content, timestamp);
        receiver->receiveMessage(m);
        sender->sendMessage(receiver->getName(), content);
    }

    // ── Reviews 
    void addReview(const Review& r) {
        if (reviewCount < MAX_REVIEWS) {
            reviews[reviewCount++] = r;
            User* u = findUser(r.getSellerID());
            if (u && u->getRole() == "Seller")
                dynamic_cast<Seller*>(u)->updateRating(r.getRating());
            cout << "[OK] Review added.\n";
        }
    }

    // ── Display 
    void displayAllListings() const {
        cout << "\n========== ALL LISTINGS (" << listingCount << ") ==========\n";
        for (int i = 0; i < listingCount; i++) listings[i]->displayDetails();
    }

    void displayApprovedListings() const {
        cout << "\n========== APPROVED LISTINGS ==========\n";
        for (int i = 0; i < listingCount; i++)
            if (listings[i]->isApproved()) listings[i]->displayDetails();
    }

    void displayStats() const {
        cout << "\n========== PLATFORM STATS ==========\n";
        cout << "Platform      : " << platformName << " v" << version << "\n";
        cout << "Total Users   : " << User::getTotalUsers()         << "\n";
        cout << "Total Vehicles: " << Vehicle::getTotalVehicles()   << "\n";
        cout << "Total Listings: " << Listing::getTotalListings()   << "\n";
        cout << "Total Searches: " << totalSearches                 << "\n";
        cout << "Platform Fee  : Rs " << Listing::getPlatformFee() << " per listing\n";
    }

    static int getTotalSearches() { return totalSearches; }
};

