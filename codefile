//  SELLER — Derived from User (Inheritance Relationship 5)
// ══════════════════════════════════════════════════════════════════════════════
class Seller : public User {
private:
    string shopName;
    bool   isVerified;
    int    totalListings;
    double averageRating;
    string cnicNumber;   // never changes after registration

public:
    // Default constructor — individual seller with no shop
    Seller() : User(), shopName("Individual"), isVerified(false),
               totalListings(0), averageRating(0.0), cnicNumber("00000-0000000-0") {}

    // Parameterized constructor — shop name and CNIC required at registration
    Seller(const string& id, const string& name, const string& email,
           const string& phone, const string& pass,
           const string& shop, const string& cnic)
        : User(id, name, email, phone, pass),
          shopName(shop), isVerified(false), totalListings(0),
          averageRating(0.0), cnicNumber(cnic) {}

    // Copy constructor
    Seller(const Seller& s)
        : User(s), shopName(s.shopName), isVerified(s.isVerified),
          totalListings(s.totalListings), averageRating(s.averageRating),
          cnicNumber(s.cnicNumber) {}

    string getRole() const override { return "Seller"; }

    // Getters
    string getShopName()      const { return shopName; }
    bool   getIsVerified()    const { return isVerified; }
    int    getTotalListings() const { return totalListings; }
    double getAvgRating()     const { return averageRating; }
    string getCNIC()          const { return cnicNumber; }

    // Setters
    void verify()             { isVerified = true; }
    void incrementListings()  { totalListings++; }
    void decrementListings()  { if (totalListings > 0) totalListings--; }

    void updateRating(double newRating) {
        averageRating = (averageRating == 0.0) ? newRating
                                               : (averageRating + newRating) / 2.0;
    }

    void displayDetails() const override {
        User::displayDetails();
        cout << "  Shop: " << shopName
             << " | Verified: " << (isVerified ? "Yes" : "No")
             << " | Listings: " << totalListings
             << " | Rating: " << averageRating << "/5\n";
    }

    // Friend function declaration
    // Justification: admin CNIC verification needs private cnicNumber
    // without adding a public getter that anyone could call
    friend bool verifyCNIC(const Seller& s, const string& cnic);
};

// Friend Function 2: Admin CNIC verification
bool verifyCNIC(const Seller& s, const string& cnic) {
    return s.cnicNumber == cnic;
}


