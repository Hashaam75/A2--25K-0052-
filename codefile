// ══════════════════════════════════════════════════════════════════════════════
//  USER — Abstract Base Class
//  Inheritance: User -> Buyer, Seller, Admin
// ══════════════════════════════════════════════════════════════════════════════
class User : public IDisplayable, public IMessagable {
protected:
    string userID;
    string name;
    string email;
    string phone;
    string passwordHash;
    bool   isActive;

    // Array of objects — inbox messages
    static const int MAX_MESSAGES = 50;
    Message inbox[MAX_MESSAGES];
    int     messageCount;

    // static: shared across ALL user instances — platform-wide count
    // Justification: total registered users is a global metric, not per-user
    static int totalUsers;

public:
    // Default constructor — used when user signs up with minimal info
    User() : userID("U000"), name("Unknown"), email(""),
             phone(""), passwordHash(""), isActive(true), messageCount(0) {
        totalUsers++;
    }

    // Parameterized constructor — used when full profile is available at registration
    User(const string& id, const string& name, const string& email,
         const string& phone, const string& pass)
        : userID(id), name(name), email(email),
          phone(phone), passwordHash(pass), isActive(true), messageCount(0) {
        totalUsers++;
    }

    // Copy constructor — used when cloning a user profile
    User(const User& u)
        : userID(u.userID + "_copy"), name(u.name), email(u.email),
          phone(u.phone), passwordHash(u.passwordHash),
          isActive(u.isActive), messageCount(u.messageCount) {
        for (int i = 0; i < messageCount; i++) inbox[i] = u.inbox[i];
        totalUsers++;
    }

    virtual ~User() {}

    // Pure virtual — each role must identify itself
    virtual string getRole() const = 0;

    // Getters
    string getUserID()   const { return userID; }
    string getName()     const { return name; }
    string getEmail()    const { return email; }
    string getPhone()    const { return phone; }
    bool   getIsActive() const { return isActive; }

    // Setters
    void setName(const string& n)  { name = n; }
    void setEmail(const string& e) { email = e; }
    void setPhone(const string& p) { phone = p; }
    void deactivate() { isActive = false; }
    void activate()   { isActive = true; }

    static int getTotalUsers() { return totalUsers; }

    // IMessagable implementation
    void sendMessage(const string& to, const string& msg) override {
        cout << "[MSG] " << name << " -> " << to << ": " << msg << "\n";
    }

    void readMessages() const override {
        cout << "=== Inbox for " << name << " (" << messageCount << " messages) ===\n";
        for (int i = 0; i < messageCount; i++) inbox[i].displayDetails();
    }

    void receiveMessage(const Message& m) {
        if (messageCount < MAX_MESSAGES)
            inbox[messageCount++] = m;
        else
            cout << "[WARN] Inbox full for " << name << "\n";
    }

    bool authenticate(const string& pass) const {
        return passwordHash == pass;
    }

    void displayDetails() const override {
        cout << "[USER:" << getRole() << "] ID:" << userID
             << " | " << name << " | " << email
             << " | Active:" << (isActive ? "Yes" : "No") << "\n";
    }
};

int User::totalUsers = 0;


